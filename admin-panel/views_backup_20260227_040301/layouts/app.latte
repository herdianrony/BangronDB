<!DOCTYPE html>
<html lang="id" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{$pageTitle ?? $title ?? $appName} - BangronDB Admin Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="/assets/css/dashboard.css" rel="stylesheet">
    <link href="/assets/css/database-management.css" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .glass { background: rgba(30, 41, 59, 0.5); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.1); }
        .glass-card { background: rgba(30, 41, 59, 0.6); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.08); }
        .stat-card { transition: all 0.2s ease; }
        .stat-card:hover { transform: translateY(-2px); box-shadow: 0 10px 40px rgba(0,0,0,0.3); }
        .progress-bar { height: 6px; border-radius: 3px; background: rgba(255,255,255,0.1); overflow: hidden; }
        .progress-bar-fill { height: 100%; border-radius: 3px; transition: width 0.5s ease; }
        .activity-item { transition: all 0.2s ease; }
        .activity-item:hover { background: rgba(255,255,255,0.05); }
        .loading-skeleton {
            background: linear-gradient(90deg, rgba(255,255,255,0.1) 25%, rgba(255,255,255,0.2) 50%, rgba(255,255,255,0.1) 75%);
            background-size: 200% 100%;
            animation: loading 1.5s infinite;
        }
        @keyframes loading {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
        .fade-in {
            animation: fadeIn 0.5s ease-in;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .sidebar-item {
            transition: all 0.2s ease;
        }
        .sidebar-item:hover {
            background: rgba(255,255,255,0.1);
        }
        .sidebar-item.active {
            background: rgba(59, 130, 246, 0.1);
            border-right: 2px solid #3b82f6;
        }
    </style>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        dark: { 800: '#1e293b', 900: '#0f172a', 950: '#020617' },
                        primary: { 50: '#eff6ff', 100: '#dbeafe', 500: '#3b82f6', 600: '#2563eb', 700: '#1d4ed8' }
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-dark-950 text-gray-100 min-h-screen" x-data="sidebarApp()">
    <!-- Sidebar -->
    <aside id="sidebar" class="fixed left-0 top-0 h-full w-64 glass z-50 transition-all duration-300">
        <div class="p-6 border-b border-white/10">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-bold">B</div>
                <div>
                    <p class="text-xs text-gray-400">BangronDB</p>
                    <h1 class="text-sm font-semibold">Admin Panel</h1>
                </div>
            </div>
        </div>
        
        <nav class="p-4 space-y-1">
            <!-- Main Navigation -->
            <a href="/dashboard" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:text-white">
                <i data-lucide="layout-dashboard" class="w-5 h-5"></i>
                <span>Dashboard</span>
            </a>
            <a href="/databases" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:text-white">
                <i data-lucide="database" class="w-5 h-5"></i>
                <span>Databases</span>
            </a>
            <a href="/collections" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:text-white">
                <i data-lucide="folder" class="w-5 h-5"></i>
                <span>Collections</span>
            </a>
            <a href="/documents" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:text-white">
                <i data-lucide="file-text" class="w-5 h-5"></i>
                <span>Documents</span>
            </a>
            <a href="/query-playground" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:text-white">
                <i data-lucide="terminal" class="w-5 h-5"></i>
                <span>Query Playground</span>
            </a>
            
            <!-- Divider -->
            <div class="pt-4 mt-4 border-t border-white/10">
                <!-- User Management -->
                <a href="/users" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:text-white">
                    <i data-lucide="users" class="w-5 h-5"></i>
                    <span>Users</span>
                </a>
                <!-- Role Management -->
                <a href="/roles" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:text-white">
                    <i data-lucide="shield" class="w-5 h-5"></i>
                    <span>Roles</span>
                </a>
                <!-- Monitoring -->
                <a href="/monitoring" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:text-white">
                    <i data-lucide="activity" class="w-5 h-5"></i>
                    <span>Monitoring</span>
                </a>
                <!-- Security -->
                <a href="/security" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:text-white">
                    <i data-lucide="lock" class="w-5 h-5"></i>
                    <span>Security</span>
                </a>
                <!-- Settings -->
                <a href="/settings" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:text-white">
                    <i data-lucide="settings" class="w-5 h-5"></i>
                    <span>Settings</span>
                </a>
            </div>
        </nav>
        
        <!-- User Profile -->
        <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-white/10">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-gradient-to-br from-green-500 to-emerald-600 rounded-full flex items-center justify-center text-sm font-bold">
                    {$user['name']|substr:0:1|upper}
                </div>
                <div class="flex-1">
                    <p class="text-sm font-medium">{$user['name'] ?? 'Admin'}</p>
                    <p class="text-xs text-gray-400">{$user['email'] ?? 'admin@bangrondb.com'}</p>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="ml-64 min-h-screen">
        <!-- Header -->
        <header class="glass sticky top-0 z-40 px-6 py-4">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <button @click="toggleSidebar" class="md:hidden p-2 hover:bg-white/10 rounded-lg transition-colors">
                        <i data-lucide="menu" class="w-5 h-5"></i>
                    </button>
                    <div>
                        <p class="text-sm text-gray-400">BangronDB Admin Panel</p>
                        <h1 class="text-lg font-semibold">{$pageTitle ?? $title ?? 'Dashboard'}</h1>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <!-- Search -->
                    <div class="hidden md:block relative">
                        <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"></i>
                        <input
                            type="text"
                            placeholder="Search databases, collections..."
                            class="pl-10 pr-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm focus:outline-none focus:border-blue-500 w-64"
                            x-model="searchQuery"
                            @input="handleSearch"
                        >
                    </div>
                    
                    <!-- Notifications -->
                    <button class="relative p-2 hover:bg-white/10 rounded-lg transition-colors" @click="toggleNotifications">
                        <i data-lucide="bell" class="w-5 h-5"></i>
                        <span x-show="notifications.length > 0" class="absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full"></span>
                    </button>
                    
                    <!-- User Menu -->
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 bg-gradient-to-br from-green-500 to-emerald-600 rounded-full flex items-center justify-center text-sm font-bold">
                            {$user['name']|substr:0:1|upper}
                        </div>
                        <span class="text-sm font-medium">{$user['name'] ?? 'Admin'}</span>
                    </div>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="p-6">
            {if $msg = flash('error')}
                <div class="mb-4 rounded-lg border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm">{$msg}</div>
            {/if}
            {if $msg = flash('success')}
                <div class="mb-4 rounded-lg border border-green-500/40 bg-green-500/10 px-4 py-3 text-sm">{$msg}</div>
            {/if}
            
            <!-- Loading State -->
            <div x-show="isLoading" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
                <div class="glass-card rounded-xl p-6">
                    <div class="loading-skeleton h-4 w-3/4 rounded mb-2"></div>
                    <div class="loading-skeleton h-8 w-1/2 rounded"></div>
                </div>
                <div class="glass-card rounded-xl p-6">
                    <div class="loading-skeleton h-4 w-3/4 rounded mb-2"></div>
                    <div class="loading-skeleton h-8 w-1/2 rounded"></div>
                </div>
                <div class="glass-card rounded-xl p-6">
                    <div class="loading-skeleton h-4 w-3/4 rounded mb-2"></div>
                    <div class="loading-skeleton h-8 w-1/2 rounded"></div>
                </div>
                <div class="glass-card rounded-xl p-6">
                    <div class="loading-skeleton h-4 w-3/4 rounded mb-2"></div>
                    <div class="loading-skeleton h-8 w-1/2 rounded"></div>
                </div>
            </div>

            <!-- Dashboard Content -->
            <div x-show="!isLoading" class="fade-in">
                {block content}{/block}
            </div>
        </main>
    </div>

    <script>
        function sidebarApp() {
            return {
                isLoading: true,
                searchQuery: '',
                notifications: [],
                realTimeData: {
                    cpu: 0,
                    memory: 0,
                    disk: 0,
                    activeConnections: 0
                },
                
                initSidebar() {
                    this.loadDashboardData();
                    this.startRealTimeUpdates();
                    
                    // Initialize Lucide icons
                    setTimeout(() => {
                        lucide.createIcons();
                    }, 100);
                    
                    // Set active sidebar item based on current page
                    this.setActiveSidebarItem();
                },
                
                setActiveSidebarItem() {
                    const currentPath = window.location.pathname;
                    const sidebarItems = document.querySelectorAll('.sidebar-item');
                    
                    sidebarItems.forEach(item => {
                        item.classList.remove('active');
                        const href = item.getAttribute('href');
                        if (href && currentPath === href) {
                            item.classList.add('active');
                        }
                    });
                },
                
                async loadDashboardData() {
                    try {
                        // Simulate loading data
                        await new Promise(resolve => setTimeout(resolve, 1500));
                        this.isLoading = false;
                    } catch (error) {
                        console.error('Error loading dashboard data:', error);
                        this.isLoading = false;
                    }
                },
                
                startRealTimeUpdates() {
                    // Update system metrics every 30 seconds
                    setInterval(() => {
                        this.updateSystemMetrics();
                    }, 30000);
                    
                    // Initial metrics update
                    this.updateSystemMetrics();
                },
                
                updateSystemMetrics() {
                    // Simulate real-time metrics updates
                    this.realTimeData.cpu = Math.floor(Math.random() * 100);
                    this.realTimeData.memory = Math.floor(Math.random() * 100);
                    this.realTimeData.disk = Math.floor(Math.random() * 100);
                    this.realTimeData.activeConnections = Math.floor(Math.random() * 1000);
                },
                
                handleSearch() {
                    // Implement search functionality
                    if (this.searchQuery.length > 2) {
                        console.log('Searching for:', this.searchQuery);
                    }
                },
                
                toggleNotifications() {
                    // Toggle notifications panel
                    console.log('Toggle notifications');
                },
                
                toggleSidebar() {
                    const sidebar = document.getElementById('sidebar');
                    sidebar.classList.toggle('-translate-x-full');
                },
                
                formatBytes(bytes) {
                    if (bytes === 0) return '0 Bytes';
                    const k = 1024;
                    const sizes = ['Bytes', 'KB', 'MB', 'GB', 'TB'];
                    const i = Math.floor(Math.log(bytes) / Math.log(k));
                    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
                }
            }
        }
    </script>
    
    <script src="/assets/js/api-service.js"></script>
    <script src="/assets/js/dashboard-utils.js"></script>
    <script src="/assets/js/dashboard.js"></script>
    <script src="/assets/js/database-management.js"></script>
    {block scripts}{/block}
</body>
</html>