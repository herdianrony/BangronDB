{layout '../layouts/main.latte'}
{block content}
<div class="rounded-xl border border-white/10 bg-white/5 p-4">
<h3 class="font-semibold mb-3">Import Roles</h3>
<form method="post" action="/roles/import" enctype="multipart/form-data" class="space-y-3">
{=csrf_field()|noescape}
<input type="file" name="file" class="w-full rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm">
<button class="rounded-lg bg-blue-600 px-4 py-2 text-sm">Import</button>
</form>
</div>
{/block}
