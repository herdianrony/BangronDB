# BangronDB Environment Configuration
# Copy this file to .env and adjust values as needed

# Database path (leave empty for in-memory database)
DB_PATH=

# Encryption key (32 bytes for AES-256-CBC, leave empty to disable encryption)
ENCRYPTION_KEY=

# Query logging (true/false)
QUERY_LOGGING=false

# Performance monitoring (true/false)
PERFORMANCE_MONITORING=false
